<groupId>com.t4wcraft</groupId>
<artifactId>InflationShop</artifactId>
<version>1.0.0</version>
<packaging>jar</packaging>

<name>InflationShop</name>
<description>Plugin de economia dinamica con inflacion y deflacion para T4WCraft</description>

<properties>
    <java.version>17</java.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
</properties>

<!-- STREAMING_CHUNK: Declaring remote repositories for dependencies -->
<repositories>
    <!-- Repositorio oficial de Spigot/Bukkit -->
    <repository>
        <id>spigotmc-repo</id>
        <url>https://hub.spigotmc.org/nexus/content/repositories/snapshots/</url>
    </repository>
    <!-- Repositorio de Vault para el manejo de dinero -->
    <repository>
        <id>jitpack.io</id>
        <url>https://jitpack.io</url>
    </repository>
</repositories>

<!-- STREAMING_CHUNK: Adding project dependencies (Spigot 1.20.4 and Vault) -->
<dependencies>
    <!-- Spigot API (Optimizado y configurado para la version 1.20.4) -->
    <dependency>
        <groupId>org.spigotmc</groupId>
        <artifactId>spigot-api</artifactId>
        <version>1.20.4-R0.1-SNAPSHOT</version>
        <scope>provided</scope>
    </dependency>
    <!-- Vault API para interactuar con la economia del servidor -->
    <dependency>
        <groupId>com.github.MilkBowl</groupId>
        <artifactId>VaultAPI</artifactId>
        <version>1.7.1</version>
        <scope>provided</scope>
    </dependency>
</dependencies>

<!-- STREAMING_CHUNK: Configuring build plugins and resources -->
<build>
    <defaultGoal>clean package</defaultGoal>
    <resources>
        <resource>
            <directory>src/main/resources</directory>
            <filtering>true</filtering>
        </resource>
    </resources>
    <plugins>
        <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-compiler-plugin</artifactId>
            <version>3.8.1</version>
            <configuration>
                <source>${java.version}</source>
                <target>${java.version}</target>
            </configuration>
        </plugin>
    </plugins>
</build>
